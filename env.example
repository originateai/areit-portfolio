# ── SUPABASE ──────────────────────────────────────────────
# From: supabase.com → project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# ── RESEND EMAIL ───────────────────────────────────────────
# From: resend.com → API Keys → Create API Key
RESEND_API_KEY=re_your_api_key_here
ALERT_EMAIL=James.storey@outlook.com.au
FROM_EMAIL=onboarding@resend.dev

# ── FRED API (free macro data) ─────────────────────────────
# From: fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ── PORTFOLIO SETTINGS ─────────────────────────────────────
MONTHLY_DEPLOY=12000
SCHOOL_FEES=60000
YIELD_TRIGGER=0.08
VIX_TRIGGER=25

# ── IG MARKETS (Phase 2 — leave as-is for now) ────────────
IG_API_KEY=
IG_USERNAME=
IG_PASSWORD=
IG_ACCOUNT_ID=
IG_DEMO=true
